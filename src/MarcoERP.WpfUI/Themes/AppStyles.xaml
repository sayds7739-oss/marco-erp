<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ═══════════════════════════════════════════════════════
         MarcoERP Global Styles
         ═══════════════════════════════════════════════════════ -->

    <!-- Color Palette -->
    <Color x:Key="PrimaryColor">#3F51B5</Color>
    <Color x:Key="PrimaryDarkColor">#303F9F</Color>
    <Color x:Key="AccentColor">#FF4081</Color>
    <Color x:Key="SidebarColor">#2C3E50</Color>
    <Color x:Key="SidebarHoverColor">#34495E</Color>
    <Color x:Key="BackgroundColor">#F5F5F5</Color>
    <Color x:Key="CardColor">#FFFFFF</Color>
    <Color x:Key="SuccessColor">#4CAF50</Color>
    <Color x:Key="WarningColor">#FF9800</Color>
    <Color x:Key="DangerColor">#F44336</Color>
    <Color x:Key="InfoColor">#2196F3</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}" />
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{StaticResource SidebarHoverColor}" />
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />

    <!-- Semantic UI Brushes -->
    <SolidColorBrush x:Key="ErrorForegroundBrush" Color="#D32F2F" />
    <SolidColorBrush x:Key="ErrorBackgroundBrush" Color="#FFEBEE" />
    <SolidColorBrush x:Key="SubtitleBrush" Color="#78909C" />
    <SolidColorBrush x:Key="StatusTextBrush" Color="#546E7A" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#90A4AE" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#B0BEC5" />
    <SolidColorBrush x:Key="DarkSurfaceBrush" Color="#37474F" />
    <SolidColorBrush x:Key="OverlayBrush" Color="#40000000" />
    <SolidColorBrush x:Key="UnsavedWarningBrush" Color="#E65100" />
    <SolidColorBrush x:Key="UnsavedWarningBackgroundBrush" Color="#FFF3E0" />
    <SolidColorBrush x:Key="ValidationErrorBrush" Color="#D32F2F" />

    <!-- ═══════════════════════════════════════════════════════
         Validation Error Template
         ═══════════════════════════════════════════════════════ -->

    <!-- Validation Error Template - Shows error message below the control -->
    <ControlTemplate x:Key="ValidationErrorTemplate">
        <StackPanel>
            <AdornedElementPlaceholder x:Name="Placeholder" />
            <TextBlock Text="{Binding ElementName=Placeholder, Path=AdornedElement.(Validation.Errors)[0].ErrorContent}"
                       Foreground="{StaticResource ValidationErrorBrush}"
                       FontSize="11"
                       FontFamily="{StaticResource ArabicFont}"
                       Margin="2,2,0,0"
                       TextWrapping="Wrap" />
        </StackPanel>
    </ControlTemplate>

    <!-- Global TextBox Style with Validation Support -->
    <Style x:Key="ValidatedTextBox" TargetType="TextBox">
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource ValidationErrorTemplate}" />
        <Setter Property="FlowDirection" Value="RightToLeft" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="#BDBDBD" />
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource ValidationErrorBrush}" />
                <Setter Property="BorderThickness" Value="2" />
                <Setter Property="Background" Value="{StaticResource ErrorBackgroundBrush}" />
                <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            </Trigger>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                <Setter Property="BorderThickness" Value="2" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Global ComboBox Style with Validation Support -->
    <Style x:Key="ValidatedComboBox" TargetType="ComboBox">
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource ValidationErrorTemplate}" />
        <Setter Property="FlowDirection" Value="RightToLeft" />
        <Setter Property="Padding" Value="6,4" />
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource ValidationErrorBrush}" />
                <Setter Property="BorderThickness" Value="2" />
                <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Font Settings -->
    <FontFamily x:Key="AppFont">Segoe UI</FontFamily>
    <FontFamily x:Key="ArabicFont">Segoe UI</FontFamily>

    <!-- Standard Margins/Paddings (compact density) -->
    <Thickness x:Key="SmallMargin">3</Thickness>
    <Thickness x:Key="StandardMargin">6</Thickness>
    <Thickness x:Key="LargeMargin">12</Thickness>
    <Thickness x:Key="FormPadding">8</Thickness>
    <Thickness x:Key="SectionSpacing">0,10,0,0</Thickness>

    <!-- Compact Density Constants -->
    <sys:Double x:Key="CompactFontSize">12</sys:Double>
    <sys:Double x:Key="CompactRowHeight">30</sys:Double>
    <sys:Double x:Key="CompactHeaderHeight">32</sys:Double>
    <sys:Double x:Key="CompactButtonHeight">30</sys:Double>
    <Thickness x:Key="CompactCellPadding">8,4,8,4</Thickness>

    <!-- Card Style -->
    <Style x:Key="CardPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBrush}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="Margin" Value="6" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.10" Color="Black" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Page Title Style -->
    <Style x:Key="PageTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="#1A237E" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <!-- Section Title Style -->
    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#37474F" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <!-- Status Badge Styles -->
    <Style x:Key="StatusBadgeDraft" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource WarningBrush}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="12,4" />
    </Style>

    <Style x:Key="StatusBadgePosted" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SuccessBrush}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="12,4" />
    </Style>

    <!-- ═══ Global DataGrid Styles ═══ -->

    <!-- Default DataGrid Column Header — ensures visible headers across all views -->
    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
        <Setter Property="Background" Value="#ECEFF1" />
        <Setter Property="Foreground" Value="#37474F" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="BorderBrush" Value="#CFD8DC" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="HorizontalContentAlignment" Value="Right" />
    </Style>

    <!-- Default DataGrid style — compact density with visible rows -->
    <Style TargetType="DataGrid" BasedOn="{StaticResource MaterialDesignDataGrid}">
        <Setter Property="ColumnHeaderHeight" Value="32" />
        <Setter Property="RowHeight" Value="30" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="#ECEFF1" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="White" />
        <Setter Property="RowBackground" Value="White" />
        <Setter Property="AlternatingRowBackground" Value="#FAFAFA" />
    </Style>

</ResourceDictionary>
