<UserControl x:Class="MarcoERP.WpfUI.Views.Accounting.ChartOfAccountsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:MarcoERP.WpfUI.Common"
             FlowDirection="RightToLeft"
             local:LoadedCommandBehavior.Command="{Binding LoadCommand}">

    <UserControl.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}" />
    </UserControl.InputBindings>

    <Grid>
        <Grid Margin="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ═══ Header / Toolbar ═══ -->
            <Border Grid.Row="0" Background="White" CornerRadius="6" Padding="10,6" Margin="4,4,4,2">
                <DockPanel>
                    <TextBlock Text="شجرة الحسابات" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"
                               DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" HorizontalAlignment="Left">
                        <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{StaticResource SuccessBrush}" Foreground="White"
                                Command="{Binding NewAccountCommand}" Height="30" Padding="12,0"
                                materialDesign:ButtonAssist.CornerRadius="4">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" VerticalAlignment="Center" />
                                <TextBlock Text="جديد" Margin="4,0,0,0" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                Command="{Binding EditSelectedAccountCommand}" Height="30" Padding="12,0" Margin="4,0,0,0"
                                materialDesign:ButtonAssist.CornerRadius="4">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Pencil" Width="14" Height="14" VerticalAlignment="Center" />
                                <TextBlock Text="تعديل" Margin="4,0,0,0" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="{StaticResource DangerBrush}"
                                Command="{Binding DeleteCommand}" Height="30" Padding="8,0" Margin="4,0,0,0">
                            <materialDesign:PackIcon Kind="Delete" Width="16" Height="16" />
                        </Button>
                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                Command="{Binding LoadCommand}" Height="30" Padding="8,0" Margin="4,0,0,0" ToolTip="تحديث">
                            <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" />
                        </Button>

                        <!-- Separator -->
                        <Border Width="1" Background="{StaticResource BackgroundBrush}" Margin="6,4" />

                        <!-- View Toggle -->
                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                Command="{Binding ToggleViewCommand}" Height="30" Padding="8,0" Margin="2,0,0,0"
                                ToolTip="تبديل عرض الشجرة / الجدول">
                            <StackPanel Orientation="Horizontal">
                                <!-- Show tree icon when in grid mode, grid icon when in tree mode -->
                                <materialDesign:PackIcon Width="16" Height="16" VerticalAlignment="Center">
                                    <materialDesign:PackIcon.Style>
                                        <Style TargetType="materialDesign:PackIcon">
                                            <Setter Property="Kind" Value="ViewList" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTreeView}" Value="False">
                                                    <Setter Property="Kind" Value="FileTree" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </materialDesign:PackIcon.Style>
                                </materialDesign:PackIcon>
                            </StackPanel>
                        </Button>

                        <!-- Expand/Collapse (only visible in tree mode) -->
                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                Command="{Binding ExpandAllCommand}" Height="30" Padding="8,0" Margin="2,0,0,0"
                                ToolTip="توسيع الكل"
                                Visibility="{Binding IsTreeView, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <materialDesign:PackIcon Kind="UnfoldMoreHorizontal" Width="16" Height="16" />
                        </Button>
                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                Command="{Binding CollapseAllCommand}" Height="30" Padding="8,0" Margin="0,0,0,0"
                                ToolTip="طي الكل"
                                Visibility="{Binding IsTreeView, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <materialDesign:PackIcon Kind="UnfoldLessHorizontal" Width="16" Height="16" />
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ═══ Error Banner ═══ -->
            <Border Grid.Row="1" Background="{StaticResource ErrorBackgroundBrush}" CornerRadius="4" Padding="8,4" Margin="6,2"
                    Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="AlertCircle" Foreground="{StaticResource ErrorForegroundBrush}" Width="16" Height="16" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorForegroundBrush}" FontSize="12"
                               Margin="6,0,0,0" TextWrapping="Wrap" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- ═══ Search Bar (tree mode only) ═══ -->
            <Border Grid.Row="2" Background="White" CornerRadius="4" Padding="8,4" Margin="4,2,4,2"
                    Visibility="{Binding IsTreeView, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <materialDesign:PackIcon Grid.Column="0" Kind="Magnify" Width="18" Height="18"
                                             Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox Grid.Column="1"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=250}"
                             materialDesign:HintAssist.Hint="بحث بالكود أو الاسم..."
                             materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                             BorderThickness="0" FontSize="12" Padding="4,4"
                             VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- ═══ Main Content Area ═══ -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- ── TreeView (visible when IsTreeView = true) ── -->
                <Border Grid.Column="0" Background="White" CornerRadius="6" Padding="4" Margin="4,2,2,2"
                        Visibility="{Binding IsTreeView, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TreeView x:Name="AccountTreeView"
                              ItemsSource="{Binding FilteredAccountTree}"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              BorderThickness="0"
                              Padding="0"
                              FontSize="13"
                              SelectedItemChanged="AccountTreeView_SelectedItemChanged">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                <Setter Property="IsExpanded" Value="True" />
                                <Setter Property="Padding" Value="2,3" />
                                <Setter Property="Margin" Value="0,1,0,0" />
                                <Style.Triggers>
                                    <!-- Inactive accounts shown with reduced opacity -->
                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                        <Setter Property="Opacity" Value="0.5" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <Grid MinHeight="24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Account Code -->
                                    <Border Grid.Column="0" Background="{StaticResource BackgroundBrush}"
                                            CornerRadius="3" Padding="6,2" Margin="0,0,6,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding AccountCode}"
                                                   FontWeight="Bold" FontSize="12"
                                                   Foreground="{StaticResource PrimaryDarkBrush}"
                                                   FlowDirection="LeftToRight"
                                                   VerticalAlignment="Center" />
                                    </Border>

                                    <!-- Folder/Leaf icon -->
                                    <materialDesign:PackIcon Grid.Column="1"
                                                             VerticalAlignment="Center" Margin="0,0,4,0"
                                                             Width="15" Height="15">
                                        <materialDesign:PackIcon.Style>
                                            <Style TargetType="materialDesign:PackIcon">
                                                <Setter Property="Kind" Value="FolderOutline" />
                                                <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLeaf}" Value="True">
                                                        <Setter Property="Kind" Value="FileDocumentOutline" />
                                                        <Setter Property="Foreground" Value="{StaticResource StatusTextBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </materialDesign:PackIcon.Style>
                                    </materialDesign:PackIcon>

                                    <!-- Account Name (Arabic) -->
                                    <TextBlock Grid.Column="2" Text="{Binding AccountNameAr}"
                                               FontSize="13" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="0,0,8,0" />

                                    <!-- Account Name (English) - smaller, muted -->
                                    <TextBlock Grid.Column="3" Text="{Binding AccountNameEn}"
                                               FontSize="11" Foreground="{StaticResource MutedTextBrush}"
                                               VerticalAlignment="Center" FlowDirection="LeftToRight"
                                               TextTrimming="CharacterEllipsis" />

                                    <!-- Account Type badge -->
                                    <Border Grid.Column="4" CornerRadius="3" Padding="5,1" Margin="8,0,0,0"
                                            VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E8EAF6" />
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding AccountTypeName}"
                                                   FontSize="10" Foreground="{StaticResource PrimaryBrush}"
                                                   VerticalAlignment="Center" />
                                    </Border>

                                    <!-- Posting indicator -->
                                    <materialDesign:PackIcon Grid.Column="5"
                                                             Kind="{Binding AllowPosting, Converter={StaticResource BoolToCheckIconConverter}}"
                                                             Foreground="{Binding AllowPosting, Converter={StaticResource BoolToColorConverter}}"
                                                             Width="14" Height="14"
                                                             VerticalAlignment="Center" Margin="8,0,0,0"
                                                             ToolTip="ترحيل" />

                                    <!-- System account lock icon -->
                                    <materialDesign:PackIcon Grid.Column="6"
                                                             Kind="Lock" Width="13" Height="13"
                                                             Foreground="{StaticResource MutedTextBrush}"
                                                             VerticalAlignment="Center" Margin="4,0,0,0"
                                                             ToolTip="حساب نظام">
                                        <materialDesign:PackIcon.Style>
                                            <Style TargetType="materialDesign:PackIcon">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSystemAccount}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </materialDesign:PackIcon.Style>
                                    </materialDesign:PackIcon>
                                </Grid>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Border>

                <!-- ── DataGrid (visible when IsTreeView = false) ── -->
                <Border Grid.Column="0" Background="White" CornerRadius="6" Padding="0" Margin="4,2,2,2"
                        Visibility="{Binding IsTreeView, Converter={StaticResource InverseBoolToVisConverter}}">
                    <DataGrid ItemsSource="{Binding AllAccounts}"
                              SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              SelectionMode="Single" GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column" FontSize="12"
                              RowHeight="30" ColumnHeaderHeight="32" BorderThickness="0"
                              materialDesign:DataGridAssist.CellPadding="8 4"
                              materialDesign:DataGridAssist.ColumnHeaderPadding="8 6">
                        <DataGrid.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding EditSelectedAccountCommand}" />
                        </DataGrid.InputBindings>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="الكود" Width="100" SortMemberPath="AccountCode">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding AccountCode}"
                                                   FontWeight="SemiBold"
                                                   FlowDirection="LeftToRight"
                                                   Foreground="{StaticResource StatusTextBrush}"
                                                   Margin="{Binding Level, Converter={StaticResource LevelToIndentConverter}}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="اسم الحساب" Binding="{Binding AccountNameAr}" Width="*" MinWidth="120" />
                            <DataGridTextColumn Header="Account Name" Binding="{Binding AccountNameEn}" Width="120" />
                            <DataGridTextColumn Header="النوع" Binding="{Binding AccountType}" Width="70" />
                            <DataGridTextColumn Header="المستوى" Binding="{Binding Level}" Width="55" />
                            <DataGridTemplateColumn Header="ترحيل" Width="45">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <materialDesign:PackIcon
                                            Kind="{Binding AllowPosting, Converter={StaticResource BoolToCheckIconConverter}}"
                                            Foreground="{Binding AllowPosting, Converter={StaticResource BoolToColorConverter}}"
                                            HorizontalAlignment="Center" Width="16" Height="16" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="نشط" Width="45">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <materialDesign:PackIcon
                                            Kind="{Binding IsActive, Converter={StaticResource BoolToCheckIconConverter}}"
                                            Foreground="{Binding IsActive, Converter={StaticResource BoolToColorConverter}}"
                                            HorizontalAlignment="Center" Width="16" Height="16" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Extra Info Panel (visible when account selected, not editing) -->
                <Border Grid.Column="1" Background="{StaticResource BackgroundBrush}" CornerRadius="6" Padding="10,8" Margin="2,2,4,2"
                        Width="200"
                        Visibility="{Binding SelectedAccount, Converter={StaticResource NullToVisibilityConverter}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="InformationOutline" Foreground="{StaticResource PrimaryBrush}"
                                                     Width="14" Height="14" VerticalAlignment="Center" />
                            <TextBlock Text="معلومات إضافية" FontSize="12" FontWeight="SemiBold"
                                       Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,3">
                            <TextBlock Text="الرصيد العادي:" FontSize="11" FontWeight="SemiBold" Width="80" Foreground="{StaticResource StatusTextBrush}" />
                            <TextBlock Text="{Binding SelectedAccount.NormalBalance}" FontSize="11" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,3">
                            <TextBlock Text="حساب نظام:" FontSize="11" FontWeight="SemiBold" Width="80" Foreground="{StaticResource StatusTextBrush}" />
                            <TextBlock Text="{Binding SelectedAccount.IsSystemAccount}" FontSize="11" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,3">
                            <TextBlock Text="العملة:" FontSize="11" FontWeight="SemiBold" Width="80" Foreground="{StaticResource StatusTextBrush}" />
                            <TextBlock Text="{Binding SelectedAccount.CurrencyCode}" FontSize="11" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,3">
                            <TextBlock Text="الحساب الأب:" FontSize="11" FontWeight="SemiBold" Width="80" Foreground="{StaticResource StatusTextBrush}" />
                            <TextBlock Text="{Binding SelectedAccount.ParentAccountNameAr}" FontSize="11" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,3">
                            <TextBlock Text="المستوى:" FontSize="11" FontWeight="SemiBold" Width="80" Foreground="{StaticResource StatusTextBrush}" />
                            <TextBlock Text="{Binding SelectedAccount.Level}" FontSize="11" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ Status Bar ═══ -->
            <Border Grid.Row="4" Padding="8,4" Margin="6,0,6,2">
                <DockPanel>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="{StaticResource MutedTextBrush}"
                               DockPanel.Dock="Right" VerticalAlignment="Center" />
                    <ProgressBar IsIndeterminate="{Binding IsBusy}" Height="2"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                                 DockPanel.Dock="Left" VerticalAlignment="Center" Width="80" Margin="0,0,8,0" />
                </DockPanel>
            </Border>
        </Grid>

        <!-- Side Drawer -->
        <Grid Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}"
              Panel.ZIndex="10">
            <Border Background="{StaticResource OverlayBrush}" Opacity="0.6">
                <Border.InputBindings>
                    <MouseBinding Gesture="LeftClick" Command="{Binding CancelCommand}" />
                </Border.InputBindings>
            </Border>

            <Border Background="White" CornerRadius="8,0,0,8"
                    HorizontalAlignment="Left" Width="400">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.2" Color="Black" Direction="180" />
                </Border.Effect>
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="{StaticResource PrimaryBrush}"
                            CornerRadius="8,0,0,0" Padding="14,10">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Right" FontSize="15" FontWeight="SemiBold" Foreground="White">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0}">
                                        <Binding Path="IsNewAccount" Converter="{StaticResource BoolToNewEditConverter}" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <Button DockPanel.Dock="Left" HorizontalAlignment="Left"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Command="{Binding CancelCommand}"
                                    Foreground="White" Padding="4" Width="28" Height="28" ToolTip="إغلاق (Esc)">
                                <materialDesign:PackIcon Kind="Close" Width="18" Height="18" />
                            </Button>
                        </DockPanel>
                    </Border>

                    <Border DockPanel.Dock="Bottom" Padding="12,8" BorderBrush="{StaticResource BackgroundBrush}" BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="{StaticResource PrimaryBrush}" Foreground="White"
                                    Command="{Binding SaveCommand}" Height="32" Padding="16,0"
                                    materialDesign:ButtonAssist.CornerRadius="4">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ContentSave" Width="16" Height="16" VerticalAlignment="Center" />
                                    <TextBlock Text="حفظ" Margin="4,0,0,0" FontSize="12" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding CancelCommand}" Height="32" Padding="16,0" Margin="6,0,0,0"
                                    materialDesign:ButtonAssist.CornerRadius="4">
                                <TextBlock Text="إلغاء" FontSize="12" />
                            </Button>
                            <Button Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="{StaticResource DangerBrush}"
                                    Command="{Binding DeactivateCommand}" Height="32" Padding="8,0" Margin="6,0,0,0"
                                    Visibility="{Binding CanDeactivate, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    ToolTip="تعطيل">
                                <materialDesign:PackIcon Kind="EyeOff" Width="16" Height="16" />
                            </Button>
                            <Button Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="{StaticResource SuccessBrush}"
                                    Command="{Binding ActivateCommand}" Height="32" Padding="8,0" Margin="2,0,0,0"
                                    Visibility="{Binding CanActivate, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    ToolTip="تفعيل">
                                <materialDesign:PackIcon Kind="Eye" Width="16" Height="16" />
                            </Button>
                        </StackPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,10">
                        <StackPanel>
                            <Border BorderBrush="{StaticResource BackgroundBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10" Margin="0,0,0,6">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <materialDesign:PackIcon Kind="FileTree" Foreground="{StaticResource PrimaryBrush}"
                                                                 Width="16" Height="16" VerticalAlignment="Center" />
                                        <TextBlock Text="بيانات الحساب" FontSize="12" FontWeight="SemiBold"
                                                   Margin="6,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBox Text="{Binding FormAccountCode, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="كود الحساب *"
                                             materialDesign:HintAssist.IsFloating="True"
                                             IsEnabled="{Binding IsNewAccount}" FontSize="12" Padding="6,4"
                                             FlowDirection="LeftToRight" MaxLength="4" />
                                    <TextBox Text="{Binding FormAccountNameAr, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="اسم الحساب (عربي) *"
                                             materialDesign:HintAssist.IsFloating="True"
                                             IsEnabled="{Binding IsEditing}" FontSize="12" Padding="6,4" Margin="0,6,0,0" />
                                    <TextBox Text="{Binding FormAccountNameEn, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Account Name (EN)"
                                             materialDesign:HintAssist.IsFloating="True"
                                             IsEnabled="{Binding IsEditing}" FontSize="12" Padding="6,4" Margin="0,6,0,0"
                                             FlowDirection="LeftToRight" />
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="{StaticResource BackgroundBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10" Margin="0,0,0,6">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <materialDesign:PackIcon Kind="Tune" Foreground="{StaticResource PrimaryBrush}"
                                                                 Width="16" Height="16" VerticalAlignment="Center" />
                                        <TextBlock Text="التصنيف" FontSize="12" FontWeight="SemiBold"
                                                   Margin="6,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="6" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0" ItemsSource="{Binding AccountTypes}"
                                                  SelectedItem="{Binding FormAccountType}"
                                                  IsEnabled="{Binding IsNewAccount}"
                                                  materialDesign:HintAssist.Hint="نوع الحساب"
                                                  materialDesign:HintAssist.IsFloating="True"
                                                  FontSize="12" Padding="6,4" />
                                        <ComboBox Grid.Column="2" ItemsSource="{Binding Levels}"
                                                  SelectedItem="{Binding FormLevel}"
                                                  IsEnabled="{Binding IsNewAccount}"
                                                  materialDesign:HintAssist.Hint="المستوى"
                                                  materialDesign:HintAssist.IsFloating="True"
                                                  FontSize="12" Padding="6,4" />
                                    </Grid>
                                    <ComboBox ItemsSource="{Binding ParentAccounts}"
                                              SelectedValue="{Binding FormParentAccountId}"
                                              SelectedValuePath="Id" DisplayMemberPath="AccountNameAr"
                                              IsEnabled="{Binding IsNewAccount}" IsEditable="True"
                                              local:F1SearchBehavior.IsEnabled="True"
                                              local:F1SearchBehavior.Title="بحث حساب رئيسي"
                                              materialDesign:HintAssist.Hint="الحساب الرئيسي"
                                              materialDesign:HintAssist.IsFloating="True"
                                              FontSize="12" Padding="6,4" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>

                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <materialDesign:PackIcon Kind="TextBox" Foreground="{StaticResource SuccessBrush}"
                                                             Width="16" Height="16" VerticalAlignment="Center" />
                                    <TextBlock Text="الوصف" FontSize="12" FontWeight="SemiBold"
                                               Margin="6,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBox Text="{Binding FormDescription, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="وصف اختياري"
                                         materialDesign:HintAssist.IsFloating="True"
                                         IsEnabled="{Binding IsEditing}" FontSize="12" Padding="6,4"
                                         TextWrapping="Wrap" MinHeight="40" AcceptsReturn="True" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
