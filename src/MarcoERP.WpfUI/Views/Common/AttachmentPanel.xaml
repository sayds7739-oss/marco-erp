<UserControl x:Class="MarcoERP.WpfUI.Views.Common.AttachmentPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">

    <GroupBox Header="المرفقات" md:ColorZoneAssist.Mode="PrimaryMid"
              Style="{StaticResource MaterialDesignGroupBox}" Margin="0,8,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Command="{Binding UploadAttachmentCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        ToolTip="إضافة مرفق" Foreground="{DynamicResource PrimaryHueMidBrush}">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Paperclip" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="إضافة مرفق" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding DeleteAttachmentCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        ToolTip="حذف المرفق المحدد" Foreground="#E53935">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Delete" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="حذف" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding OpenAttachmentCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        ToolTip="فتح المرفق" Foreground="#43A047">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="OpenInNew" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="فتح" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Attachments List -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Attachments}"
                      SelectedItem="{Binding SelectedAttachment}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Single"
                      MaxHeight="200"
                      Style="{StaticResource MaterialDesignDataGrid}"
                      md:DataGridAssist.ColumnHeaderPadding="8 4"
                      md:DataGridAssist.CellPadding="8 4">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="اسم الملف" Binding="{Binding FileName}" Width="*"/>
                    <DataGridTextColumn Header="الحجم" Binding="{Binding FileSizeDisplay}" Width="100"/>
                    <DataGridTextColumn Header="المستخدم" Binding="{Binding UploadedBy}" Width="120"/>
                    <DataGridTextColumn Header="التاريخ" Binding="{Binding UploadedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="140"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Empty state -->
            <TextBlock Grid.Row="1"
                       Text="لا توجد مرفقات"
                       Foreground="#90A4AE"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="{Binding HasNoAttachments, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </Grid>
    </GroupBox>
</UserControl>
