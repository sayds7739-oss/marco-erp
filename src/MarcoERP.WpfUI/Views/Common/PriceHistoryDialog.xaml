<Window x:Class="MarcoERP.WpfUI.Views.Common.PriceHistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="سجل الأسعار"
        Width="560" SizeToContent="Height" MaxHeight="600"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="Segoe UI"
        TextElement.FontSize="12">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Border Padding="14,12" Background="White">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <materialDesign:PackIcon Kind="History" Width="22" Height="22"
                                         Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" />
                <TextBlock Text="سجل الأسعار" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}" Margin="8,0,0,0" VerticalAlignment="Center" />
            </StackPanel>

            <Border CornerRadius="4" Padding="10,6" Margin="0,0,0,10"
                    Background="#F5F7FA" BorderBrush="#E0E0E0" BorderThickness="1"
                    Visibility="{Binding HasCounterpartyPrice, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <TextBlock Text="{Binding CounterpartyLabel}" FontWeight="SemiBold" DockPanel.Dock="Right" />
                    <TextBlock Text="{Binding CounterpartyPrice, StringFormat=N2}"
                               FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"
                               DockPanel.Dock="Left" />
                </DockPanel>
            </Border>

            <DataGrid ItemsSource="{Binding RecentPrices}"
                      SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      SelectionMode="Single" GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column" FontSize="12"
                      RowHeight="30" ColumnHeaderHeight="32" BorderThickness="0"
                      materialDesign:DataGridAssist.CellPadding="8 4"
                      materialDesign:DataGridAssist.ColumnHeaderPadding="8 6"
                      MouseDoubleClick="PricesGrid_DoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="التاريخ" Binding="{Binding InvoiceDate, StringFormat=yyyy-MM-dd}" Width="110" />
                    <DataGridTextColumn Header="رقم المستند" Binding="{Binding DocumentNumber}" Width="130" />
                    <DataGridTextColumn Header="الطرف" Binding="{Binding CounterpartyNameAr}" Width="*" MinWidth="140" />
                    <DataGridTextColumn Header="السعر" Binding="{Binding UnitPrice, StringFormat=N2}" Width="90" />
                    <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity, StringFormat=0.00}" Width="80" />
                </DataGrid.Columns>
            </DataGrid>

            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="{StaticResource PrimaryBrush}" Foreground="White"
                        Click="ApplySelected_Click" Margin="4,0"
                        Height="32" Padding="14,0"
                        IsEnabled="{Binding CanApplySelected}">
                    <TextBlock Text="استخدام السعر المحدد" FontSize="12" />
                </Button>

                <Button Grid.Column="2"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Click="ApplyCounterparty_Click" Margin="4,0"
                        Height="32" Padding="14,0"
                        Visibility="{Binding HasCounterpartyPrice, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="استخدام آخر سعر" FontSize="12" />
                </Button>

                <Button Grid.Column="3"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Click="Cancel_Click" Margin="4,0"
                        Height="32" Padding="14,0">
                    <TextBlock Text="إلغاء" FontSize="12" />
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</Window>
