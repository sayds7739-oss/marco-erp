<Window x:Class="MarcoERP.WpfUI.Views.Common.SendEmailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="إرسال بالبريد الإلكتروني" Height="320" Width="480"
        WindowStartupLocation="CenterOwner" FlowDirection="RightToLeft"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Style="{StaticResource MaterialDesignWindow}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="إرسال الفاتورة بالبريد الإلكتروني" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,12" />

        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="البريد الإلكتروني" FontSize="12" Margin="0,0,0,4" />
            <TextBox x:Name="EmailTextBox" 
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     materialDesign:HintAssist.Hint="example@domain.com"
                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,8">
            <TextBlock Text="رسالة إضافية (اختياري)" FontSize="12" Margin="0,0,0,4" />
            <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     materialDesign:HintAssist.Hint="رسالة مرفقة..."
                     Text="{Binding Message, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" MaxHeight="80"
                     VerticalScrollBarVisibility="Auto" />
        </StackPanel>

        <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" Foreground="Red" FontSize="11"
                   Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}"
                   VerticalAlignment="Bottom" Margin="0,0,0,8" />

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Left">
            <Button Content="إرسال" Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="{DynamicResource PrimaryHueMidBrush}" Foreground="White"
                    Click="OnSendClick" Margin="0,0,8,0" MinWidth="100" />
            <Button Content="إلغاء" Style="{StaticResource MaterialDesignOutlinedButton}"
                    Click="OnCancelClick" MinWidth="80" />
        </StackPanel>
    </Grid>
</Window>
