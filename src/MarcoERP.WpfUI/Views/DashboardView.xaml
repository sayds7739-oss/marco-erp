<UserControl x:Class="MarcoERP.WpfUI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:charts="clr-namespace:MarcoERP.WpfUI.Controls"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <!-- ═══ Color-Coded Card Backgrounds (subtle gradients) ═══ -->
        <LinearGradientBrush x:Key="SalesCardBg" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F1F8E9" Offset="0" />
            <GradientStop Color="#E8F5E9" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PurchaseCardBg" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF8E1" Offset="0" />
            <GradientStop Color="#FFF3E0" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="ReceiptCardBg" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#E3F2FD" Offset="0" />
            <GradientStop Color="#E1F5FE" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PaymentCardBg" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFEBEE" Offset="0" />
            <GradientStop Color="#FCE4EC" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="ProfitCardBg" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#EDE7F6" Offset="0" />
            <GradientStop Color="#E8EAF6" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CashBalanceCardBg" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#E0F2F1" Offset="0" />
            <GradientStop Color="#E8F5E9" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CustomerCardBg" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#E3F2FD" Offset="0" />
            <GradientStop Color="#E8EAF6" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="SupplierCardBg" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF3E0" Offset="0" />
            <GradientStop Color="#FFF8E1" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="AlertCardBg" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF8E1" Offset="0" />
            <GradientStop Color="#FFEBEE" Offset="1" />
        </LinearGradientBrush>

        <!-- ═══ Icon circle backgrounds ═══ -->
        <SolidColorBrush x:Key="SalesIconBg" Color="#C8E6C9" />
        <SolidColorBrush x:Key="PurchaseIconBg" Color="#FFE0B2" />
        <SolidColorBrush x:Key="ReceiptIconBg" Color="#BBDEFB" />
        <SolidColorBrush x:Key="PaymentIconBg" Color="#FFCDD2" />
        <SolidColorBrush x:Key="ProfitIconBg" Color="#D1C4E9" />
        <SolidColorBrush x:Key="CashIconBg" Color="#B2DFDB" />
        <SolidColorBrush x:Key="CustomerIconBg" Color="#C5CAE9" />
        <SolidColorBrush x:Key="SupplierIconBg" Color="#FFE0B2" />

        <!-- ═══ Accent colors for values ═══ -->
        <SolidColorBrush x:Key="SalesAccent" Color="#2E7D32" />
        <SolidColorBrush x:Key="PurchaseAccent" Color="#E65100" />
        <SolidColorBrush x:Key="ReceiptAccent" Color="#1565C0" />
        <SolidColorBrush x:Key="PaymentAccent" Color="#C62828" />
        <SolidColorBrush x:Key="ProfitAccent" Color="#4527A0" />
        <SolidColorBrush x:Key="CashAccent" Color="#00695C" />

        <!-- Delta up/down arrow colors -->
        <SolidColorBrush x:Key="DeltaPositiveBrush" Color="#2E7D32" />
        <SolidColorBrush x:Key="DeltaNegativeBrush" Color="#C62828" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
        <StackPanel>

            <!-- ═══ Header ═══ -->
            <DockPanel Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <Border Background="{StaticResource PrimaryBrush}" CornerRadius="8" Padding="8" Margin="0,0,12,0"
                            VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="ViewDashboardOutline" Width="24" Height="24"
                                                 Foreground="White" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="لوحة التحكم" FontSize="22" FontWeight="Bold"
                                   Foreground="#1A237E" />
                        <TextBlock Text="نظرة عامة على أداء الأعمال" FontSize="12"
                                   Foreground="{StaticResource SubtitleBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
                <Button DockPanel.Dock="Left" Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding RefreshCommand}" HorizontalAlignment="Left"
                        ToolTip="تحديث البيانات" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20" VerticalAlignment="Center" />
                        <TextBlock Text="تحديث" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <materialDesign:PopupBox DockPanel.Dock="Left" HorizontalAlignment="Left"
                                         ToolTip="تخصيص أقسام لوحة التحكم" Margin="8,0,0,0"
                                         PlacementMode="BottomAndAlignCentres" StaysOpen="True">
                    <materialDesign:PopupBox.ToggleContent>
                        <materialDesign:PackIcon Kind="TuneVertical" Width="20" Height="20"
                                                 Foreground="{StaticResource SubtitleBrush}" />
                    </materialDesign:PopupBox.ToggleContent>
                    <Border Background="White" Padding="16" MinWidth="220">
                        <StackPanel>
                            <TextBlock Text="إظهار/إخفاء الأقسام" FontWeight="Bold" FontSize="13" Margin="0,0,0,8" />
                            <CheckBox Content="الاختصارات السريعة" IsChecked="{Binding ShowShortcutsSection}" Margin="0,4" />
                            <CheckBox Content="أداء اليوم" IsChecked="{Binding ShowTodaySection}" Margin="0,4" />
                            <CheckBox Content="الأرصدة الجارية" IsChecked="{Binding ShowBalancesSection}" Margin="0,4" />
                            <CheckBox Content="التنبيهات والمؤشرات" IsChecked="{Binding ShowAlertsSection}" Margin="0,4" />
                            <CheckBox Content="الأداء الشهري" IsChecked="{Binding ShowMonthSection}" Margin="0,4" />
                            <CheckBox Content="الرسوم البيانية" IsChecked="{Binding ShowChartsSection}" Margin="0,4" />
                        </StackPanel>
                    </Border>
                </materialDesign:PopupBox>
            </DockPanel>

            <!-- ═══ Quick Access Shortcuts ═══ -->
            <DockPanel Margin="0,0,0,8" Visibility="{Binding ShowShortcutsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="RocketLaunchOutline" Width="18" Height="18"
                                             Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"
                                             Margin="0,0,6,0" />
                    <TextBlock Text="الوصول السريع" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" Foreground="#37474F" />
                </StackPanel>
                <Button DockPanel.Dock="Left" HorizontalAlignment="Left"
                        Style="{StaticResource MaterialDesignIconButton}"
                        Command="{Binding ConfigureShortcutsCommand}"
                        ToolTip="تخصيص الاختصارات" Width="28" Height="28" Padding="0">
                    <materialDesign:PackIcon Kind="Cog" Width="16" Height="16" />
                </Button>
            </DockPanel>

            <ItemsControl ItemsSource="{Binding Shortcuts}" Margin="0,0,0,16" Visibility="{Binding ShowShortcutsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="6" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="4" Padding="12" Cursor="Hand"
                                CornerRadius="10"
                                Background="{DynamicResource MaterialDesignCardBackground}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.10" Color="Black" />
                            </Border.Effect>
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick" Command="{Binding NavigateCommand}" />
                            </Border.InputBindings>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1.05" Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1.05" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1.0" Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1.0" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <Border.RenderTransformOrigin>
                                <Point X="0.5" Y="0.5" />
                            </Border.RenderTransformOrigin>
                            <StackPanel HorizontalAlignment="Center">
                                <Border Width="44" Height="44" CornerRadius="22"
                                        Background="#EDE7F6"
                                        HorizontalAlignment="Center" Margin="0,0,0,8">
                                    <materialDesign:PackIcon Kind="{Binding IconKind}" Width="24" Height="24"
                                                             Foreground="{Binding IconBrush}"
                                                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" TextAlignment="Center"
                                           Foreground="#37474F" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ═══ Today's Metrics - Color-Coded Cards ═══ -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10" Visibility="{Binding ShowTodaySection, Converter={StaticResource BooleanToVisibilityConverter}}">
                <materialDesign:PackIcon Kind="CalendarToday" Width="20" Height="20"
                                         Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"
                                         Margin="0,0,6,0" />
                <TextBlock Text="أداء اليوم" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center" Foreground="#1A237E" />
            </StackPanel>
            <UniformGrid Columns="5" Margin="0,0,0,16" Visibility="{Binding ShowTodaySection, Converter={StaticResource BooleanToVisibilityConverter}}">

                <!-- Today Sales (GREEN) -->
                <Border Margin="4" Padding="18" CornerRadius="12" Background="{StaticResource SalesCardBg}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Color="#388E3C" />
                    </Border.Effect>
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <Border Width="42" Height="42" CornerRadius="12" Background="{StaticResource SalesIconBg}">
                                <materialDesign:PackIcon Kind="CashRegister" Width="22" Height="22"
                                                         Foreground="{StaticResource SalesAccent}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock DockPanel.Dock="Left" Text="{Binding TodaySalesDelta, StringFormat=+0.00;-0.00;0.00}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource SubtitleBrush}"
                                       HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,4,0,0" />
                        </DockPanel>
                        <TextBlock Text="المبيعات" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#37474F" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding TodaySales, StringFormat=N2}" FontSize="24"
                                   FontWeight="Bold" Foreground="{StaticResource SalesAccent}" />
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <materialDesign:PackIcon Kind="Receipt" Width="14" Height="14"
                                                     Foreground="{StaticResource SubtitleBrush}" VerticalAlignment="Center" />
                            <TextBlock Foreground="{StaticResource SubtitleBrush}" FontSize="12" Margin="4,0,0,0"
                                       VerticalAlignment="Center">
                                <Run Text="{Binding TodaySalesCount, Mode=OneWay}" FontWeight="SemiBold" />
                                <Run Text=" فاتورة" />
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Today Purchases (AMBER/ORANGE) -->
                <Border Margin="4" Padding="18" CornerRadius="12" Background="{StaticResource PurchaseCardBg}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Color="#E65100" />
                    </Border.Effect>
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <Border Width="42" Height="42" CornerRadius="12" Background="{StaticResource PurchaseIconBg}">
                                <materialDesign:PackIcon Kind="CartArrowDown" Width="22" Height="22"
                                                         Foreground="{StaticResource PurchaseAccent}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock DockPanel.Dock="Left" Text="{Binding TodayPurchasesDelta, StringFormat=+0.00;-0.00;0.00}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource SubtitleBrush}"
                                       HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,4,0,0" />
                        </DockPanel>
                        <TextBlock Text="المشتريات" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#37474F" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding TodayPurchases, StringFormat=N2}" FontSize="24"
                                   FontWeight="Bold" Foreground="{StaticResource PurchaseAccent}" />
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <materialDesign:PackIcon Kind="Receipt" Width="14" Height="14"
                                                     Foreground="{StaticResource SubtitleBrush}" VerticalAlignment="Center" />
                            <TextBlock Foreground="{StaticResource SubtitleBrush}" FontSize="12" Margin="4,0,0,0"
                                       VerticalAlignment="Center">
                                <Run Text="{Binding TodayPurchasesCount, Mode=OneWay}" FontWeight="SemiBold" />
                                <Run Text=" فاتورة" />
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Today Cash In (BLUE) -->
                <Border Margin="4" Padding="18" CornerRadius="12" Background="{StaticResource ReceiptCardBg}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Color="#1565C0" />
                    </Border.Effect>
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <Border Width="42" Height="42" CornerRadius="12" Background="{StaticResource ReceiptIconBg}">
                                <materialDesign:PackIcon Kind="CashPlus" Width="22" Height="22"
                                                         Foreground="{StaticResource ReceiptAccent}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock DockPanel.Dock="Left" Text="{Binding TodayReceiptsDelta, StringFormat=+0.00;-0.00;0.00}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource SubtitleBrush}"
                                       HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,4,0,0" />
                        </DockPanel>
                        <TextBlock Text="المقبوضات" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#37474F" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding TodayReceipts, StringFormat=N2}" FontSize="24"
                                   FontWeight="Bold" Foreground="{StaticResource ReceiptAccent}" />
                    </StackPanel>
                </Border>

                <!-- Today Cash Out (RED) -->
                <Border Margin="4" Padding="18" CornerRadius="12" Background="{StaticResource PaymentCardBg}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Color="#C62828" />
                    </Border.Effect>
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <Border Width="42" Height="42" CornerRadius="12" Background="{StaticResource PaymentIconBg}">
                                <materialDesign:PackIcon Kind="CashMinus" Width="22" Height="22"
                                                         Foreground="{StaticResource PaymentAccent}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock DockPanel.Dock="Left" Text="{Binding TodayPaymentsDelta, StringFormat=+0.00;-0.00;0.00}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource SubtitleBrush}"
                                       HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,4,0,0" />
                        </DockPanel>
                        <TextBlock Text="المدفوعات" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#37474F" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding TodayPayments, StringFormat=N2}" FontSize="24"
                                   FontWeight="Bold" Foreground="{StaticResource PaymentAccent}" />
                    </StackPanel>
                </Border>

                <!-- Today Net Profit (PURPLE) -->
                <Border Margin="4" Padding="18" CornerRadius="12" Background="{StaticResource ProfitCardBg}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Color="#4527A0" />
                    </Border.Effect>
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <Border Width="42" Height="42" CornerRadius="12" Background="{StaticResource ProfitIconBg}">
                                <materialDesign:PackIcon Kind="TrendingUp" Width="22" Height="22"
                                                         Foreground="{StaticResource ProfitAccent}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </DockPanel>
                        <TextBlock Text="صافي اليوم" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#37474F" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding DailyNetProfit, StringFormat=N2}" FontSize="24"
                                   FontWeight="Bold" Foreground="{StaticResource ProfitAccent}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ═══ Month Metrics ═══ -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10" Visibility="{Binding ShowMonthSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                <materialDesign:PackIcon Kind="CalendarMonth" Width="20" Height="20"
                                         Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"
                                         Margin="0,0,6,0" />
                <TextBlock Text="أداء الشهر الحالي" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center" Foreground="#1A237E" />
            </StackPanel>
            <UniformGrid Columns="5" Margin="0,0,0,16" Visibility="{Binding ShowMonthSection, Converter={StaticResource BooleanToVisibilityConverter}}">

                <!-- Month Sales -->
                <Border Margin="4" Padding="16" CornerRadius="10" Background="{StaticResource SalesCardBg}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.06" Color="Black" />
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="32" Height="32" CornerRadius="8" Background="{StaticResource SalesIconBg}">
                                <materialDesign:PackIcon Kind="CashRegister" Width="16" Height="16"
                                                         Foreground="{StaticResource SalesAccent}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="مبيعات الشهر" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#546E7A" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding MonthSales, StringFormat=N2}" FontSize="20"
                                   FontWeight="Bold" Foreground="{StaticResource SalesAccent}" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding MonthSalesDelta, StringFormat=+0.00;-0.00;0.00}"
                                   Foreground="{StaticResource SubtitleBrush}" FontSize="11"
                                   FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Month Purchases -->
                <Border Margin="4" Padding="16" CornerRadius="10" Background="{StaticResource PurchaseCardBg}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.06" Color="Black" />
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="32" Height="32" CornerRadius="8" Background="{StaticResource PurchaseIconBg}">
                                <materialDesign:PackIcon Kind="CartArrowDown" Width="16" Height="16"
                                                         Foreground="{StaticResource PurchaseAccent}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="مشتريات الشهر" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#546E7A" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding MonthPurchases, StringFormat=N2}" FontSize="20"
                                   FontWeight="Bold" Foreground="{StaticResource PurchaseAccent}" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding MonthPurchasesDelta, StringFormat=+0.00;-0.00;0.00}"
                                   Foreground="{StaticResource SubtitleBrush}" FontSize="11"
                                   FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Month Receipts -->
                <Border Margin="4" Padding="16" CornerRadius="10" Background="{StaticResource ReceiptCardBg}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.06" Color="Black" />
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="32" Height="32" CornerRadius="8" Background="{StaticResource ReceiptIconBg}">
                                <materialDesign:PackIcon Kind="CashPlus" Width="16" Height="16"
                                                         Foreground="{StaticResource ReceiptAccent}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="مقبوضات الشهر" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#546E7A" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding MonthReceipts, StringFormat=N2}" FontSize="20"
                                   FontWeight="Bold" Foreground="{StaticResource ReceiptAccent}" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding MonthReceiptsDelta, StringFormat=+0.00;-0.00;0.00}"
                                   Foreground="{StaticResource SubtitleBrush}" FontSize="11"
                                   FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Month Payments -->
                <Border Margin="4" Padding="16" CornerRadius="10" Background="{StaticResource PaymentCardBg}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.06" Color="Black" />
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="32" Height="32" CornerRadius="8" Background="{StaticResource PaymentIconBg}">
                                <materialDesign:PackIcon Kind="CashMinus" Width="16" Height="16"
                                                         Foreground="{StaticResource PaymentAccent}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="مدفوعات الشهر" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#546E7A" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding MonthPayments, StringFormat=N2}" FontSize="20"
                                   FontWeight="Bold" Foreground="{StaticResource PaymentAccent}" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding MonthPaymentsDelta, StringFormat=+0.00;-0.00;0.00}"
                                   Foreground="{StaticResource SubtitleBrush}" FontSize="11"
                                   FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Gross Margin -->
                <Border Margin="4" Padding="16" CornerRadius="10" Background="{StaticResource ProfitCardBg}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.06" Color="Black" />
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="32" Height="32" CornerRadius="8" Background="{StaticResource ProfitIconBg}">
                                <materialDesign:PackIcon Kind="Percent" Width="16" Height="16"
                                                         Foreground="{StaticResource ProfitAccent}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="هامش الربح" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#546E7A" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding GrossMarginPercent, StringFormat={}{0:N2}%}" FontSize="20"
                                   FontWeight="Bold" Foreground="{StaticResource ProfitAccent}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ═══ Running Balances ═══ -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10" Visibility="{Binding ShowBalancesSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                <materialDesign:PackIcon Kind="WalletOutline" Width="20" Height="20"
                                         Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"
                                         Margin="0,0,6,0" />
                <TextBlock Text="الأرصدة الجارية" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center" Foreground="#1A237E" />
            </StackPanel>
            <UniformGrid Columns="4" Margin="0,0,0,16" Visibility="{Binding ShowBalancesSection, Converter={StaticResource BooleanToVisibilityConverter}}">

                <!-- Cash Balance -->
                <Border Margin="4" Padding="18" CornerRadius="12" Background="{StaticResource CashBalanceCardBg}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Color="#00695C" />
                    </Border.Effect>
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <Border Width="46" Height="46" CornerRadius="14" Background="{StaticResource CashIconBg}">
                                <materialDesign:PackIcon Kind="Safe" Width="24" Height="24"
                                                         Foreground="{StaticResource CashAccent}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </DockPanel>
                        <TextBlock Text="رصيد الصندوق" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#37474F" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding CashBalance, StringFormat=N2}" FontSize="26"
                                   FontWeight="Bold" Foreground="{StaticResource CashAccent}" />
                    </StackPanel>
                </Border>

                <!-- Customer AR -->
                <Border Margin="4" Padding="18" CornerRadius="12" Background="{StaticResource CustomerCardBg}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Color="#1565C0" />
                    </Border.Effect>
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <Border Width="46" Height="46" CornerRadius="14" Background="{StaticResource CustomerIconBg}">
                                <materialDesign:PackIcon Kind="AccountGroupOutline" Width="24" Height="24"
                                                         Foreground="{StaticResource ReceiptAccent}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </DockPanel>
                        <TextBlock Text="ذمم العملاء" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#37474F" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding TotalCustomerBalance, StringFormat=N2}" FontSize="26"
                                   FontWeight="Bold" Foreground="{StaticResource ReceiptAccent}" />
                    </StackPanel>
                </Border>

                <!-- Supplier AP -->
                <Border Margin="4" Padding="18" CornerRadius="12" Background="{StaticResource SupplierCardBg}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Color="#E65100" />
                    </Border.Effect>
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <Border Width="46" Height="46" CornerRadius="14" Background="{StaticResource SupplierIconBg}">
                                <materialDesign:PackIcon Kind="TruckDeliveryOutline" Width="24" Height="24"
                                                         Foreground="{StaticResource PurchaseAccent}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </DockPanel>
                        <TextBlock Text="ذمم الموردين" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#37474F" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding TotalSupplierBalance, StringFormat=N2}" FontSize="26"
                                   FontWeight="Bold" Foreground="{StaticResource PurchaseAccent}" />
                    </StackPanel>
                </Border>

                <!-- Month Gross Profit -->
                <Border Margin="4" Padding="18" CornerRadius="12" Background="{StaticResource ProfitCardBg}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Color="#4527A0" />
                    </Border.Effect>
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <Border Width="46" Height="46" CornerRadius="14" Background="{StaticResource ProfitIconBg}">
                                <materialDesign:PackIcon Kind="ChartLineVariant" Width="24" Height="24"
                                                         Foreground="{StaticResource ProfitAccent}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </DockPanel>
                        <TextBlock Text="مجمل ربح الشهر" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#37474F" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding MonthGrossProfit, StringFormat=N2}" FontSize="26"
                                   FontWeight="Bold" Foreground="{StaticResource ProfitAccent}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ═══ Alerts ═══ -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10" Visibility="{Binding ShowAlertsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                <materialDesign:PackIcon Kind="BellAlertOutline" Width="20" Height="20"
                                         Foreground="{StaticResource DangerBrush}" VerticalAlignment="Center"
                                         Margin="0,0,6,0" />
                <TextBlock Text="تنبيهات" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center" Foreground="#1A237E" />
            </StackPanel>
            <UniformGrid Columns="3" Margin="0,0,0,16" Visibility="{Binding ShowAlertsSection, Converter={StaticResource BooleanToVisibilityConverter}}">

                <!-- Low Stock Alert -->
                <Border Margin="4" Padding="18" CornerRadius="12">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFEBEE" Offset="0" />
                            <GradientStop Color="#FFCDD2" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08" Color="#C62828" />
                    </Border.Effect>
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <Border Width="42" Height="42" CornerRadius="12" Background="#FFCDD2">
                                <materialDesign:PackIcon Kind="AlertCircleOutline" Width="22" Height="22"
                                                         Foreground="#C62828"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock DockPanel.Dock="Left" Text="تحذير" FontSize="11"
                                       FontWeight="Bold" Foreground="#C62828"
                                       HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,4,0,0" />
                        </DockPanel>
                        <TextBlock Text="أصناف تحت الحد الأدنى" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#37474F" Margin="0,0,0,6" />
                        <TextBlock FontSize="28" FontWeight="Bold">
                            <Run Text="{Binding LowStockCount, Mode=OneWay}"
                                 Foreground="#C62828" />
                            <Run Text=" / " Foreground="{StaticResource SecondaryTextBrush}" FontSize="18" />
                            <Run Text="{Binding TotalProducts, Mode=OneWay}" Foreground="{StaticResource SubtitleBrush}" FontSize="18" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Pending Sales / Purchase Invoices -->
                <Border Margin="4" Padding="18" CornerRadius="12">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFF8E1" Offset="0" />
                            <GradientStop Color="#FFE0B2" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08" Color="#E65100" />
                    </Border.Effect>
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <Border Width="42" Height="42" CornerRadius="12" Background="#FFE0B2">
                                <materialDesign:PackIcon Kind="FileDocumentEditOutline" Width="22" Height="22"
                                                         Foreground="#E65100"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock DockPanel.Dock="Left" Text="معلّقة" FontSize="11"
                                       FontWeight="Bold" Foreground="#E65100"
                                       HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,4,0,0" />
                        </DockPanel>
                        <TextBlock Text="مسودات معلّقة" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#37474F" Margin="0,0,0,8" />
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <materialDesign:PackIcon Kind="ReceiptTextOutline" Width="16" Height="16"
                                                         Foreground="#E65100" VerticalAlignment="Center" />
                                <TextBlock FontSize="13" Margin="6,0,0,0" VerticalAlignment="Center">
                                    <Run Text="فواتير بيع: " Foreground="#546E7A" />
                                    <Run Text="{Binding PendingSalesInvoices, Mode=OneWay}" FontWeight="Bold" Foreground="#E65100" />
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <materialDesign:PackIcon Kind="CartOutline" Width="16" Height="16"
                                                         Foreground="#E65100" VerticalAlignment="Center" />
                                <TextBlock FontSize="13" Margin="6,0,0,0" VerticalAlignment="Center">
                                    <Run Text="فواتير شراء: " Foreground="#546E7A" />
                                    <Run Text="{Binding PendingPurchaseInvoices, Mode=OneWay}" FontWeight="Bold" Foreground="#E65100" />
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Pending Journals -->
                <Border Margin="4" Padding="18" CornerRadius="12">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#E8EAF6" Offset="0" />
                            <GradientStop Color="#C5CAE9" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08" Color="#283593" />
                    </Border.Effect>
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <Border Width="42" Height="42" CornerRadius="12" Background="#C5CAE9">
                                <materialDesign:PackIcon Kind="BookOpenPageVariant" Width="22" Height="22"
                                                         Foreground="#283593"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock DockPanel.Dock="Left" Text="مسودة" FontSize="11"
                                       FontWeight="Bold" Foreground="#283593"
                                       HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,4,0,0" />
                        </DockPanel>
                        <TextBlock Text="قيود مسودة" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#37474F" Margin="0,0,0,6" />
                        <TextBlock Text="{Binding PendingJournalEntries}" FontSize="28"
                                   FontWeight="Bold" Foreground="#283593" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ═══════════════════ CHARTS ═══════════════════ -->
            <UniformGrid Columns="2" Margin="0,8,0,0" Visibility="{Binding ShowChartsSection, Converter={StaticResource BooleanToVisibilityConverter}}">

                <!-- Sales/Purchase Trend (Line Chart) -->
                <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,6,0"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.08" />
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="ChartLine" Width="18" Height="18"
                                                     Foreground="#4CAF50" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="اتجاه المبيعات والمشتريات (4 أسابيع)" FontSize="12"
                                       FontWeight="SemiBold" VerticalAlignment="Center" />
                            <StackPanel Orientation="Horizontal" Margin="14,0,0,0">
                                <Ellipse Width="8" Height="8" Fill="#4CAF50" Margin="0,0,4,0" VerticalAlignment="Center" />
                                <TextBlock Text="مبيعات" FontSize="9" Foreground="#78909C" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <Ellipse Width="8" Height="8" Fill="#FF5722" Margin="0,0,4,0" VerticalAlignment="Center" />
                                <TextBlock Text="مشتريات" FontSize="9" Foreground="#78909C" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                        <charts:SimpleLineChart Grid.Row="1" Height="180"
                            ItemsSource="{Binding SalesTrendData}"
                            ValuePath="SalesTotal" LabelPath="Label"
                            SecondValuePath="PurchaseTotal"
                            LineBrush="#4CAF50" SecondLineBrush="#FF5722">
                            <charts:SimpleLineChart.FillBrush>
                                <SolidColorBrush Color="#4CAF50" Opacity="0.1" />
                            </charts:SimpleLineChart.FillBrush>
                        </charts:SimpleLineChart>
                    </Grid>
                </Border>

                <!-- Top Products (Bar Chart) -->
                <Border Background="White" CornerRadius="10" Padding="14" Margin="6,0,0,0"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.08" />
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="ChartBar" Width="18" Height="18"
                                                     Foreground="#2196F3" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="أعلى 5 أصناف مبيعاً (هذا الشهر)" FontSize="12"
                                       FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                        <charts:SimpleBarChart Grid.Row="1" Height="180"
                            ItemsSource="{Binding TopProductsData}"
                            ValuePath="Value" LabelPath="Label"
                            MaxBars="5">
                            <charts:SimpleBarChart.BarBrush>
                                <SolidColorBrush Color="#2196F3" />
                            </charts:SimpleBarChart.BarBrush>
                        </charts:SimpleBarChart>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- Error message -->
            <Border Background="{StaticResource ErrorBackgroundBrush}" CornerRadius="8" Padding="14" Margin="0,8"
                    Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="AlertCircle" Width="20" Height="20"
                                             Foreground="{StaticResource DangerBrush}" VerticalAlignment="Center"
                                             Margin="0,0,8,0" />
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                               FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
