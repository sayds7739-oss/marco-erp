<UserControl x:Class="MarcoERP.WpfUI.Views.Inventory.BulkPriceUpdateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             FlowDirection="RightToLeft">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ══════ Title ══════ -->
        <Border Grid.Row="0" Style="{StaticResource CardPanel}" Padding="12,8" Margin="0,0,0,4">
            <DockPanel>
                <TextBlock Text="تحديث الأسعار الجماعي" Style="{StaticResource PageTitle}"
                           DockPanel.Dock="Right" Margin="0" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" HorizontalAlignment="Left">
                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                            Command="{Binding LoadCommand}" ToolTip="تحديث" Margin="4,0">
                        <materialDesign:PackIcon Kind="Refresh" />
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══════ Error Bar ══════ -->
        <Border Grid.Row="1" Background="{StaticResource ErrorBackgroundBrush}" CornerRadius="4" Padding="10,6" Margin="8,2"
                Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="AlertCircle" Foreground="{StaticResource ErrorForegroundBrush}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorForegroundBrush}"
                           Margin="8,0,0,0" TextWrapping="Wrap" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- ══════ Controls Panel ══════ -->
        <Border Grid.Row="2" Style="{StaticResource CardPanel}" Margin="0,2,0,2" Padding="10,7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <RadioButton Content="نسبة مئوية" GroupName="Mode" IsChecked="{Binding IsPercentageMode}" Margin="0,0,10,0" />
                    <RadioButton Content="سعر مباشر" GroupName="Mode" IsChecked="{Binding IsDirectMode}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="السعر المستهدف" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource SubtitleBrush}" />
                    <ComboBox SelectedValue="{Binding SelectedPriceTarget}" Width="125" SelectedValuePath="Tag">
                        <ComboBoxItem Tag="SalePrice" Content="سعر البيع" />
                        <ComboBoxItem Tag="CostPrice" Content="سعر التكلفة" />
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding IsPercentageMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="النسبة (%)" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource SubtitleBrush}" />
                    <TextBox Text="{Binding PercentageChange, StringFormat=N2, UpdateSourceTrigger=LostFocus}"
                             Width="110" FontSize="13" FlowDirection="LeftToRight" Padding="6,4" />
                </StackPanel>

                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding IsDirectMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="السعر الجديد" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource SubtitleBrush}" />
                    <TextBox Text="{Binding DirectPrice, StringFormat=N2, UpdateSourceTrigger=LostFocus}"
                             Width="110" FontSize="13" FlowDirection="LeftToRight" Padding="6,4" />
                </StackPanel>

                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <TextBlock Text="مستوى الوحدة" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource SubtitleBrush}" />
                    <RadioButton Content="الكلية" GroupName="UnitLevel" IsChecked="{Binding IsMajorUnitLevel}" Margin="0,0,8,0" />
                    <RadioButton Content="الصغرى" GroupName="UnitLevel" IsChecked="{Binding IsMinorUnitLevel}" Margin="0,0,10,0" />
                    <CheckBox Content="مزامنة التحويل" IsChecked="{Binding SyncByConversion}" Margin="0,0,10,0" VerticalAlignment="Center" />

                    <Button Style="{StaticResource MaterialDesignRaisedButton}" Command="{Binding SelectAllCommand}" ToolTip="تحديد الكل" Margin="2,0">
                        <TextBlock Text="تحديد الكل" />
                    </Button>
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding DeselectAllCommand}" ToolTip="إلغاء التحديد" Margin="2,0">
                        <TextBlock Text="إلغاء التحديد" />
                    </Button>
                    <Button Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource WarningBrush}" Foreground="White"
                            Command="{Binding PreviewCommand}" ToolTip="معاينة" Margin="2,0">
                        <TextBlock Text="معاينة" />
                    </Button>
                    <Button Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource SuccessBrush}" Foreground="White"
                            Command="{Binding ApplyCommand}" ToolTip="تطبيق" Margin="2,0"
                            Visibility="{Binding ShowPreview, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="تطبيق" />
                    </Button>
                </StackPanel>

                <TextBox Grid.Column="7"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="بحث عن صنف..."
                         FontSize="12" Padding="8,5" Width="220" HorizontalAlignment="Right" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- ══════ Product List (full width, with preview columns that appear after preview) ══════ -->
        <Border Grid.Row="3" Style="{StaticResource CardPanel}" Margin="0,0,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource SectionTitle}">
                    <Run Text="الأصناف" />
                    <Run Text=" — " Foreground="{StaticResource SecondaryTextBrush}" />
                    <Run Text="{Binding SelectedCount, Mode=OneWay, FallbackValue=0}" FontWeight="Bold" />
                    <Run Text=" محدد" />
                </TextBlock>
                <DataGrid ItemsSource="{Binding AllProducts}"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          CanUserDeleteRows="False" SelectionMode="Single"
                          GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                                      FontSize="12" RowHeight="31" ColumnHeaderHeight="32" BorderThickness="0"
                          materialDesign:DataGridAssist.CellPadding="10 6"
                          materialDesign:DataGridAssist.ColumnHeaderPadding="10 8">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                Header="✓" Width="40" />
                        <DataGridTextColumn Header="الكود" Binding="{Binding Code}" Width="80" IsReadOnly="True" />
                                                <DataGridTextColumn Header="اسم الصنف" Binding="{Binding NameAr}" Width="280" IsReadOnly="True" />
                                                <DataGridTextColumn Header="الوحدة" Binding="{Binding BaseUnitName}" Width="88" IsReadOnly="True"
                                                                                        Visibility="{Binding DataContext.ShowMajorColumns, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                <DataGridTextColumn Header="سعر بيع" Binding="{Binding DefaultSalePrice, StringFormat=N2}" Width="86" IsReadOnly="True"
                                                                                        Visibility="{Binding DataContext.ShowMajorColumns, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                <DataGridTextColumn Header="سعر تكلفة" Binding="{Binding CostPrice, StringFormat=N2}" Width="90" IsReadOnly="True"
                                                                                        Visibility="{Binding DataContext.ShowMajorColumns, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                                <DataGridTextColumn Header="الوحدة" Binding="{Binding MinorUnitName}" Width="88" IsReadOnly="True"
                                                                                        Visibility="{Binding DataContext.ShowMinorColumns, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                <DataGridTextColumn Header="معامل" Binding="{Binding MinorUnitFactor, StringFormat=N0}" Width="70" IsReadOnly="True"
                                                                                        Visibility="{Binding DataContext.ShowMinorColumns, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                <DataGridTextColumn Header="سعر بيع" Binding="{Binding MinorSalePrice, StringFormat=N2}" Width="86" IsReadOnly="True"
                                                                                        Visibility="{Binding DataContext.ShowMinorColumns, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                <DataGridTextColumn Header="سعر تكلفة" Binding="{Binding MinorCostPrice, StringFormat=N2}" Width="90" IsReadOnly="True"
                                                                                        Visibility="{Binding DataContext.ShowMinorColumns, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <DataGridTextColumn Header="السعر المطلوب" Binding="{Binding NewPrice, StringFormat=N2}" Width="84" IsReadOnly="True"
                                            Visibility="{Binding DataContext.ShowPreview, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            FontWeight="Bold">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="بعد التحديث" Binding="{Binding PreviewMajorPrice, StringFormat=N2}" Width="92" IsReadOnly="True"
                                            Visibility="{Binding DataContext.ShowMajorPreviewColumns, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <DataGridTextColumn Header="بعد التحديث" Binding="{Binding PreviewMinorPrice, StringFormat=N2}" Width="92" IsReadOnly="True"
                                            Visibility="{Binding DataContext.ShowMinorPreviewColumns, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <DataGridTextColumn Header="الفرق" Binding="{Binding Difference, StringFormat=N2}" Width="78" IsReadOnly="True"
                                            Visibility="{Binding DataContext.ShowPreview, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <DataGridTextColumn Header="%" Binding="{Binding PercentageChange, StringFormat=N1}" Width="56" IsReadOnly="True"
                                            Visibility="{Binding DataContext.ShowPreview, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- ══════ Status Bar ══════ -->
        <Border Grid.Row="4" Padding="10,6" Margin="8,4,8,0">
            <DockPanel>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SubtitleBrush}" FontSize="12" />
                <ProgressBar IsIndeterminate="{Binding IsBusy}"
                             Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                             Height="3" DockPanel.Dock="Left" Width="100" Margin="16,0,0,0" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
