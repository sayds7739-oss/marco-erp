<UserControl x:Class="MarcoERP.WpfUI.Views.Settings.PrintCenterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:MarcoERP.WpfUI.Common"
             FlowDirection="RightToLeft" Background="{StaticResource BackgroundBrush}"
             local:LoadedCommandBehavior.Command="{Binding LoadCommand}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ══════ Title + Toolbar ══════ -->
        <Border Grid.Row="0" Style="{StaticResource CardPanel}" Padding="12" Margin="0,0,0,8">
            <DockPanel>
                <TextBlock Text="مركز الطباعة" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}" DockPanel.Dock="Right" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                            Command="{Binding SaveCommand}" Margin="4,0"
                            Background="{StaticResource SuccessBrush}" Foreground="White">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" />
                            <TextBlock Text="حفظ الإعدادات" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding PreviewCommand}" Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Eye" VerticalAlignment="Center" />
                            <TextBlock Text="معاينة" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding ResetDefaultsCommand}" Margin="4,0"
                            Foreground="{StaticResource WarningBrush}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Restore" VerticalAlignment="Center" />
                            <TextBlock Text="استعادة الافتراضي" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══════ Settings Content ══════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ── Section: Colors ── -->
                <Border Style="{StaticResource CardPanel}" Padding="16" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="🎨 الألوان" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"
                                   Foreground="{StaticResource PrimaryBrush}" />

                        <UniformGrid Columns="3" Margin="0,0,0,8">
                            <StackPanel Margin="0,0,16,8">
                                <TextBlock Text="اللون الرئيسي" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="#1565C0"
                                         Text="{Binding PrimaryColor, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,16,8">
                                <TextBlock Text="خلفية العناوين" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="#ECEFF1"
                                         Text="{Binding HeaderBgColor, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,16,8">
                                <TextBlock Text="لون الحدود" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="#CFD8DC"
                                         Text="{Binding BorderColor, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,16,8">
                                <TextBlock Text="لون النص" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="#263238"
                                         Text="{Binding TextColor, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,16,8">
                                <TextBlock Text="لون النص الفرعي" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="#607D8B"
                                         Text="{Binding SubtitleColor, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- ── Section: Fonts ── -->
                <Border Style="{StaticResource CardPanel}" Padding="16" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="🔤 الخطوط" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"
                                   Foreground="{StaticResource PrimaryBrush}" />

                        <UniformGrid Columns="3" Margin="0,0,0,8">
                            <StackPanel Margin="0,0,16,8">
                                <TextBlock Text="نوع الخط" FontSize="12" Margin="0,0,0,4" />
                                <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          ItemsSource="{Binding AvailableFonts}"
                                          Text="{Binding FontFamily, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="True" />
                            </StackPanel>
                            <StackPanel Margin="0,0,16,8">
                                <TextBlock Text="حجم خط العنوان" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="20"
                                         Text="{Binding TitleFontSize, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,16,8">
                                <TextBlock Text="حجم خط المحتوى" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="12"
                                         Text="{Binding BodyFontSize, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- ── Section: Layout ── -->
                <Border Style="{StaticResource CardPanel}" Padding="16" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="📐 التخطيط والعرض" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"
                                   Foreground="{StaticResource PrimaryBrush}" />

                        <WrapPanel Margin="0,0,0,8">
                            <CheckBox Content="عرض الشعار" IsChecked="{Binding ShowLogo}" Margin="0,0,24,8" />
                            <CheckBox Content="عرض اسم الشركة" IsChecked="{Binding ShowCompanyName}" Margin="0,0,24,8" />
                            <CheckBox Content="عرض العنوان" IsChecked="{Binding ShowAddress}" Margin="0,0,24,8" />
                            <CheckBox Content="عرض هاتف / بريد" IsChecked="{Binding ShowContact}" Margin="0,0,24,8" />
                            <CheckBox Content="عرض الرقم الضريبي" IsChecked="{Binding ShowTaxNumber}" Margin="0,0,24,8" />
                            <CheckBox Content="عرض التذييل" IsChecked="{Binding ShowFooter}" Margin="0,0,24,8" />
                        </WrapPanel>

                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="نص التذييل" FontSize="12" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="MarcoERP — نظام إدارة الأعمال"
                                     Text="{Binding FooterText, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── Section: Section Ordering ── -->
                <Border Style="{StaticResource CardPanel}" Padding="16" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="ترتيب الأقسام" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"
                                   Foreground="{StaticResource PrimaryBrush}" />
                        <TextBlock Text="حدد قسماً واستخدم الأسهم لتغيير ترتيب الأقسام في المستند المطبوع."
                                   FontSize="12" Foreground="{StaticResource SubtitleBrush}" Margin="0,0,0,8" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ListBox Grid.Column="0" ItemsSource="{Binding Sections}" SelectedItem="{Binding SelectedSection}"
                                     MinHeight="180" MaxHeight="260"
                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="4,2">
                                            <materialDesign:PackIcon Kind="DragVertical" VerticalAlignment="Center"
                                                                     Foreground="{StaticResource SubtitleBrush}" Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding DisplayName}" FontSize="13" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                <Button Style="{StaticResource MaterialDesignIconButton}"
                                        Command="{Binding MoveSectionUpCommand}" ToolTip="تحريك لأعلى" Margin="0,0,0,4">
                                    <materialDesign:PackIcon Kind="ArrowUp" />
                                </Button>
                                <Button Style="{StaticResource MaterialDesignIconButton}"
                                        Command="{Binding MoveSectionDownCommand}" ToolTip="تحريك لأسفل">
                                    <materialDesign:PackIcon Kind="ArrowDown" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── Section: Column Visibility ── -->
                <Border Style="{StaticResource CardPanel}" Padding="16" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="أعمدة الجدول" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"
                                   Foreground="{StaticResource PrimaryBrush}" />
                        <TextBlock Text="اختر الأعمدة التي تريد إظهارها في جدول البنود."
                                   FontSize="12" Foreground="{StaticResource SubtitleBrush}" Margin="0,0,0,8" />

                        <ItemsControl ItemsSource="{Binding ColumnVisibility}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding ColumnHeader}" IsChecked="{Binding IsVisible}"
                                              Margin="0,0,24,8" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ── Section: Custom HTML ── -->
                <Border Style="{StaticResource CardPanel}" Padding="16" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="محتوى مخصص" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"
                                   Foreground="{StaticResource PrimaryBrush}" />
                        <TextBlock Text="أضف محتوى HTML مخصص يُعرض بعد رأس الشركة أو قبل التذييل."
                                   FontSize="12" Foreground="{StaticResource SubtitleBrush}" Margin="0,0,0,8" />

                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="HTML مخصص بعد رأس الشركة" FontSize="12" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="&lt;div&gt;...&lt;/div&gt;"
                                     Text="{Binding CustomHeaderHtml, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" MaxHeight="120"
                                     VerticalScrollBarVisibility="Auto" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,0">
                            <TextBlock Text="HTML مخصص قبل التذييل" FontSize="12" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="&lt;div&gt;...&lt;/div&gt;"
                                     Text="{Binding CustomFooterHtml, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" MaxHeight="120"
                                     VerticalScrollBarVisibility="Auto" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── Info Note ── -->
                <Border Style="{StaticResource CardPanel}" Padding="16" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="📌 ملاحظة" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"
                                   Foreground="{StaticResource InfoBrush}" />
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource SubtitleBrush}">
                            <Run Text="هذه الإعدادات تُطبق على جميع المستندات القابلة للطباعة: فواتير البيع والشراء، المرتجعات، عروض الأسعار، سندات القبض والصرف، القيود اليومية، والتحويلات." />
                            <LineBreak /><LineBreak />
                            <Run Text="معلومات الشركة (الاسم، العنوان، الهاتف، الرقم الضريبي) يتم تعديلها من " />
                            <Run Text="إعدادات النظام" FontWeight="Bold" />
                            <Run Text=" ← مجموعة 'معلومات الشركة'." />
                            <LineBreak /><LineBreak />
                            <Run Text="استخدم زر 'معاينة' لرؤية شكل المستند قبل الحفظ." />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Success/Error messages -->
                <Border Background="#E8F5E9" CornerRadius="4" Padding="10,6" Margin="0,0,0,4"
                        Visibility="{Binding HasSuccess, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="{StaticResource SuccessBrush}" />
                </Border>
                <Border Background="{StaticResource ErrorBackgroundBrush}" CornerRadius="4" Padding="10,6" Margin="0,0,0,4"
                        Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" />
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.RowSpan="2" Background="#60000000" CornerRadius="4"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Style="{StaticResource MaterialDesignCircularProgressBar}"
                             Width="48" Height="48" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
