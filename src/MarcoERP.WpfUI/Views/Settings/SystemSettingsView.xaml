<UserControl x:Class="MarcoERP.WpfUI.Views.Settings.SystemSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:MarcoERP.WpfUI.Common"
             xmlns:conv="clr-namespace:MarcoERP.WpfUI.Converters"
             FlowDirection="RightToLeft" Background="{StaticResource BackgroundBrush}"
             local:LoadedCommandBehavior.Command="{Binding LoadCommand}">

    <UserControl.Resources>
        <conv:StringBoolConverter x:Key="StringBoolConverter"/>

        <!-- String editor: standard TextBox -->
        <DataTemplate x:Key="StringEditorTemplate">
            <TextBox VerticalAlignment="Center"
                     Text="{Binding SettingValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     materialDesign:HintAssist.Hint="القيمة"
                     FlowDirection="LeftToRight" FontSize="13" Padding="10,8" />
        </DataTemplate>

        <!-- Bool editor: ToggleButton with label -->
        <DataTemplate x:Key="BoolEditorTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}"
                              IsChecked="{Binding SettingValue, Converter={StaticResource StringBoolConverter}, Mode=TwoWay}"
                              Margin="0,0,10,0" />
                <TextBlock VerticalAlignment="Center" FontSize="13"
                           Foreground="{StaticResource SubtitleBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="معطل"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SettingValue}" Value="true">
                                    <Setter Property="Text" Value="مفعّل"/>
                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </DataTemplate>

        <!-- Numeric editor: TextBox with input restriction hint -->
        <DataTemplate x:Key="NumericEditorTemplate">
            <TextBox VerticalAlignment="Center"
                     Text="{Binding SettingValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     materialDesign:HintAssist.Hint="رقم"
                     FlowDirection="LeftToRight" FontSize="13" Padding="10,8"
                     InputScope="Number" />
        </DataTemplate>

        <local:SettingEditorTemplateSelector x:Key="SettingEditorSelector"
            StringTemplate="{StaticResource StringEditorTemplate}"
            BoolTemplate="{StaticResource BoolEditorTemplate}"
            NumericTemplate="{StaticResource NumericEditorTemplate}" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────── -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Cog" Width="28" Height="28" Foreground="White"
                                             VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBlock Text="إعدادات النظام" FontSize="22" FontWeight="Bold" Foreground="White"
                               VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Command="{Binding SaveAllCommand}" Margin="6,0"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="White" Foreground="{StaticResource PrimaryBrush}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" />
                            <TextBlock Text="حفظ الكل" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding LoadCommand}"
                            Style="{StaticResource MaterialDesignFlatLightBgButton}" Foreground="White">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" VerticalAlignment="Center" />
                            <TextBlock Text="تحديث" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Group Filter ──────────────────────────── -->
        <Border Grid.Row="1" Background="White" Padding="16,12" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="FilterVariant" Width="20" Height="20"
                                         Foreground="{StaticResource SubtitleBrush}"
                                         VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Text="المجموعة:" VerticalAlignment="Center" Margin="0,0,10,0"
                           FontWeight="SemiBold" FontSize="13"/>
                <ComboBox ItemsSource="{Binding GroupNames}"
                          SelectedItem="{Binding SelectedGroup}"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Width="280" materialDesign:HintAssist.Hint="اختر مجموعة"
                          FontSize="13" />
            </StackPanel>
        </Border>

        <!-- ── Settings List ─────────────────────────── -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="16,8">
            <StackPanel>
                <ItemsControl ItemsSource="{Binding FilteredSettings}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="8" Margin="0,0,0,10" Padding="18,14"
                                    BorderBrush="#E8E8E8" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.06" Color="Black" />
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="320"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Setting Description + Key -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0">
                                        <TextBlock Text="{Binding Description}" FontWeight="SemiBold" FontSize="14"
                                                   TextWrapping="Wrap" Foreground="#333" />
                                        <TextBlock Text="{Binding SettingKey}" Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="11" FlowDirection="LeftToRight"
                                                   HorizontalAlignment="Left" Margin="0,4,0,0" />
                                        <Border CornerRadius="4" Padding="6,2" Margin="0,6,0,0"
                                                HorizontalAlignment="Left" Background="{StaticResource BackgroundBrush}">
                                            <TextBlock Text="{Binding GroupName}" Foreground="{StaticResource PrimaryBrush}"
                                                       FontSize="11" FontWeight="SemiBold" />
                                        </Border>
                                    </StackPanel>

                                    <!-- Value Editor (type-aware) -->
                                    <ContentControl Grid.Column="1" Content="{Binding}"
                                                    ContentTemplateSelector="{StaticResource SettingEditorSelector}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Background="White" CornerRadius="8" Margin="0,0,0,10" Padding="18,14"
                        BorderBrush="#E8E8E8" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.06" Color="Black" />
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AlertOutline" Width="20" Height="20" Foreground="{StaticResource DangerBrush}" Margin="0,0,8,0" />
                                <TextBlock Text="مسح البيانات التشغيلية" FontWeight="Bold" FontSize="14" Foreground="#333" />
                            </StackPanel>
                            <TextBlock Text="يتم حذف البيانات التشغيلية من قاعدة البيانات داخل معاملة واحدة (Transaction) مع إمكانية الإبقاء على بيانات رئيسية محددة."
                                       TextWrapping="Wrap" Margin="0,6,0,10" Foreground="{StaticResource SubtitleBrush}" FontSize="12" />

                            <WrapPanel>
                                <CheckBox Content="الإبقاء على العملاء" IsChecked="{Binding KeepCustomers}" Margin="0,0,16,6" />
                                <CheckBox Content="الإبقاء على الموردين" IsChecked="{Binding KeepSuppliers}" Margin="0,0,16,6" />
                                <CheckBox Content="الإبقاء على الأصناف" IsChecked="{Binding KeepProducts}" Margin="0,0,16,6" />
                                <CheckBox Content="الإبقاء على مندوبي المبيعات" IsChecked="{Binding KeepSalesRepresentatives}" Margin="0,0,16,6" />
                            </WrapPanel>

                            <TextBlock Text="{Binding PurgeSummary}" Foreground="{StaticResource SubtitleBrush}" FontSize="11" Margin="0,8,0,0" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Command="{Binding PurgeDataCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{StaticResource DangerBrush}" Foreground="White"
                                Margin="16,0,0,0" Padding="14,8" VerticalAlignment="Top">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="DatabaseRemove" VerticalAlignment="Center" />
                                <TextBlock Text="مسح البيانات" Margin="6,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- ── Status Bar ─────────────────────────────── -->
        <Border Grid.Row="3" Background="White" Padding="16,10" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="InformationOutline" Width="16" Height="16"
                                             Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"
                                             Margin="0,0,6,0" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SubtitleBrush}"
                               FontSize="12" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                           Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}"
                           HorizontalAlignment="Left" FontSize="12" />
                <ProgressBar IsIndeterminate="{Binding IsBusy}" HorizontalAlignment="Right" Width="120"
                             Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
