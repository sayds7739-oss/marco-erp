<Window x:Class="MarcoERP.WpfUI.Views.Setup.OnboardingWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="MarcoERP — معالج الإعداد الأولي" Height="550" Width="700"
        WindowStartupLocation="CenterScreen" FlowDirection="RightToLeft"
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">

    <Border Background="White" CornerRadius="12" Margin="8"
            Effect="{StaticResource MaterialDesignShadowDepth3}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource PrimaryHueMidBrush}" CornerRadius="12,12,0,0" Padding="24,16">
                <StackPanel>
                    <TextBlock Text="MarcoERP" FontSize="24" FontWeight="Bold" Foreground="White" />
                    <TextBlock Text="معالج الإعداد الأولي" FontSize="14" Foreground="#B3FFFFFF" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <!-- Progress Bar -->
            <Grid Grid.Row="1" Margin="24,16,24,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ProgressBar Grid.Column="0" Value="{Binding ProgressPercent}" Maximum="100" Height="6"
                             Foreground="{DynamicResource PrimaryHueMidBrush}" Background="#E0E0E0" />
                <TextBlock Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource PrimaryHueMidBrush}">
                    <Run Text="الخطوة" />
                    <Run Text="{Binding CurrentStep, Mode=OneWay}" />
                    <Run Text="من" />
                    <Run Text="4" />
                </TextBlock>
            </Grid>

            <!-- Step Content -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="24,0">
                <Grid>
                    <!-- Step Title -->
                    <StackPanel>
                        <TextBlock Text="{Binding StepTitle}" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding StepDescription}" FontSize="12" Foreground="Gray"
                                   TextWrapping="Wrap" Margin="0,0,0,16" />

                        <!-- Step 1: Company Info -->
                        <StackPanel Visibility="{Binding IsStep1, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="اسم الشركة *" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="مثال: شركة المستقبل للتجارة" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="العنوان" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding CompanyAddress, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="العنوان الكامل" />
                            </StackPanel>
                            <UniformGrid Columns="2" Margin="0,0,0,12">
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="الهاتف" FontSize="12" Margin="0,0,0,4" />
                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             Text="{Binding CompanyPhone, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="8,0,0,0">
                                    <TextBlock Text="البريد الإلكتروني" FontSize="12" Margin="0,0,0,4" />
                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             Text="{Binding CompanyEmail, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </UniformGrid>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="الرقم الضريبي" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding CompanyTaxNumber, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Step 2: Fiscal Year -->
                        <StackPanel Visibility="{Binding IsStep2, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <UniformGrid Columns="2" Margin="0,0,0,12">
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="بداية السنة المالية" FontSize="12" Margin="0,0,0,4" />
                                    <DatePicker Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                                SelectedDate="{Binding FiscalYearStart}" />
                                </StackPanel>
                                <StackPanel Margin="8,0,0,0">
                                    <TextBlock Text="نهاية السنة المالية" FontSize="12" Margin="0,0,0,4" />
                                    <DatePicker Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                                SelectedDate="{Binding FiscalYearEnd}" />
                                </StackPanel>
                            </UniformGrid>
                            <Border Background="#E3F2FD" CornerRadius="4" Padding="12" Margin="0,8,0,0">
                                <TextBlock Text="ملاحظة: يمكنك لاحقاً إدارة السنوات المالية والفترات المحاسبية من قسم المحاسبة."
                                           TextWrapping="Wrap" FontSize="11" Foreground="#1565C0" />
                            </Border>
                        </StackPanel>

                        <!-- Step 3: Warehouse -->
                        <StackPanel Visibility="{Binding IsStep3, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <UniformGrid Columns="2" Margin="0,0,0,12">
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="كود المستودع" FontSize="12" Margin="0,0,0,4" />
                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             Text="{Binding WarehouseCode, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="8,0,0,0">
                                    <TextBlock Text="اسم المستودع *" FontSize="12" Margin="0,0,0,4" />
                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             Text="{Binding WarehouseName, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </UniformGrid>
                            <Border Background="#E8F5E9" CornerRadius="4" Padding="12" Margin="0,8,0,0">
                                <TextBlock Text="سيتم إنشاء المستودع عند فتح قسم المخزون. يمكنك إضافة مستودعات إضافية لاحقاً."
                                           TextWrapping="Wrap" FontSize="11" Foreground="#2E7D32" />
                            </Border>
                        </StackPanel>

                        <!-- Step 4: Cashbox -->
                        <StackPanel Visibility="{Binding IsStep4, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <UniformGrid Columns="2" Margin="0,0,0,12">
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="كود الصندوق" FontSize="12" Margin="0,0,0,4" />
                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             Text="{Binding CashboxCode, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="8,0,0,0">
                                    <TextBlock Text="اسم الصندوق *" FontSize="12" Margin="0,0,0,4" />
                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             Text="{Binding CashboxName, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </UniformGrid>
                            <Border Background="#FFF8E1" CornerRadius="4" Padding="12" Margin="0,8,0,0">
                                <TextBlock Text="الصندوق يستخدم لعمليات القبض والصرف النقدية. يمكنك إضافة حسابات بنكية لاحقاً."
                                           TextWrapping="Wrap" FontSize="11" Foreground="#F57F17" />
                            </Border>
                        </StackPanel>

                        <!-- Error Message -->
                        <Border Background="#FFEBEE" CornerRadius="4" Padding="10,6" Margin="0,12,0,0"
                                Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" FontSize="12" />
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <!-- Navigation Buttons -->
            <Border Grid.Row="3" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Margin="24,8,24,0" Padding="0,12,0,0">
                <DockPanel>
                    <Button DockPanel.Dock="Left" Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding SkipCommand}" Content="تخطي" Foreground="Gray" />

                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                Command="{Binding BackCommand}" Content="السابق" Margin="0,0,8,0"
                                Visibility="{Binding CanGoBack, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                Command="{Binding NextCommand}" MinWidth="120"
                                Background="{DynamicResource PrimaryHueMidBrush}" Foreground="White">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="التالي" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLastStep}" Value="True">
                                                    <Setter Property="Text" Value="إنهاء الإعداد" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <materialDesign:PackIcon Margin="6,0,0,0" VerticalAlignment="Center">
                                    <materialDesign:PackIcon.Style>
                                        <Style TargetType="materialDesign:PackIcon">
                                            <Setter Property="Kind" Value="ArrowLeft" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLastStep}" Value="True">
                                                    <Setter Property="Kind" Value="Check" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </materialDesign:PackIcon.Style>
                                </materialDesign:PackIcon>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Loading Overlay -->
            <Border Grid.RowSpan="5" Background="#60FFFFFF" CornerRadius="12"
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 Width="48" Height="48" />
                    <TextBlock Text="جاري الحفظ..." Margin="0,12,0,0" FontSize="14" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Height="16" />
        </Grid>
    </Border>
</Window>
