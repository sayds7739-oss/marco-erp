<Window x:Class="MarcoERP.WpfUI.Views.Shell.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:MarcoERP.WpfUI.Common"
        Title="MarcoERP — تسجيل الدخول"
        Height="560" Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft"
        FocusManager.FocusedElement="{Binding ElementName=txtUsername}">

    <Window.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding LoginCommand}" />
    </Window.InputBindings>

    <Border CornerRadius="16"
            Background="White"
            BorderThickness="0"
            local:WindowDragBehavior.IsEnabled="True">

        <Border.Effect>
            <DropShadowEffect BlurRadius="35" ShadowDepth="0" Opacity="0.30" Color="#1A237E"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header with gradient -->
            <Border Grid.Row="0"
                    CornerRadius="16,16,0,0"
                    Padding="24,28">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#283593" Offset="0" />
                        <GradientStop Color="#3F51B5" Offset="0.5" />
                        <GradientStop Color="#5C6BC0" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <StackPanel HorizontalAlignment="Center">
                    <!-- Logo icon in a circle -->
                    <Border Width="64" Height="64" CornerRadius="32"
                            Background="#FFFFFF20"
                            HorizontalAlignment="Center" Margin="0,0,0,12">
                        <Border Width="52" Height="52" CornerRadius="26"
                                Background="#FFFFFF30"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="Domain"
                                                     Width="32"
                                                     Height="32"
                                                     Foreground="White"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                        </Border>
                    </Border>
                    <TextBlock Text="MarcoERP"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               FlowDirection="LeftToRight"/>
                    <TextBlock Text="نظام إدارة الموارد المتكامل"
                               FontSize="13"
                               Foreground="#B8C4FF"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Form -->
            <StackPanel Grid.Row="1"
                        Margin="32,24,32,28"
                        VerticalAlignment="Center">

                <TextBlock Text="تسجيل الدخول"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#1A237E"
                           Margin="0,0,0,20"
                           HorizontalAlignment="Center"/>

                <TextBox x:Name="txtUsername"
                         materialDesign:HintAssist.Hint="اسم المستخدم"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="14"
                         Margin="0,0,0,16"/>

                <Grid Margin="0,0,0,8">
                    <PasswordBox x:Name="txtPassword"
                                 materialDesign:HintAssist.Hint="كلمة المرور"
                                 materialDesign:HintAssist.IsFloating="True"
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                 local:PasswordBoxAssistant.BoundPassword="{Binding Password, Mode=TwoWay}"
                                 FontSize="14"
                                 Padding="0,0,36,0"
                                 Visibility="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolToVisConverter}}" />
                    <TextBox materialDesign:HintAssist.Hint="كلمة المرور"
                             materialDesign:HintAssist.IsFloating="True"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="14"
                             Padding="0,0,36,0"
                             Visibility="{Binding IsPasswordVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ToggleButton Style="{StaticResource MaterialDesignIconForegroundButton}"
                                  IsChecked="{Binding IsPasswordVisible}"
                                  HorizontalAlignment="Left" VerticalAlignment="Center"
                                  Margin="281,0,0,0" Padding="4"
                                  ToolTip="إظهار/إخفاء كلمة المرور" Width="68" Height="43">
                        <materialDesign:PackIcon Kind="EyeOutline" Width="23" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </ToggleButton>
                </Grid>

                <!-- Remember Me -->
                <CheckBox Content="تذكرني"
                          IsChecked="{Binding RememberMe}"
                          FontSize="12"
                          Margin="0,4,0,16"
                          FlowDirection="RightToLeft"
                          VerticalContentAlignment="Center" />

                <!-- Loading Indicator -->
                <ProgressBar x:Name="progressBar"
                             Height="4"
                             IsIndeterminate="True"
                             Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                             Margin="0,0,0,12"/>

                <!-- Error Message -->
                <Border CornerRadius="8" Padding="10" Margin="0,0,0,12"
                        Background="#FFEBEE"
                        Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AlertCircle" Width="18" Height="18"
                                                 Foreground="#C62828" VerticalAlignment="Center"
                                                 Margin="0,0,8,0" />
                        <TextBlock x:Name="lblError"
                                   Foreground="#C62828"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="{Binding ErrorMessage}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Login Button with gradient -->
                <Button x:Name="btnLogin"
                        Height="44"
                        Cursor="Hand"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="White"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                        Command="{Binding LoginCommand}"
                        ToolTip="تسجيل الدخول">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#3F51B5" Offset="0" />
                                        <GradientStop Color="#5C6BC0" Offset="1" />
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="BorderThickness" Value="0" />
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Login" Width="20" Height="20"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="دخول" VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold" />
                    </StackPanel>
                </Button>

                <Button Content="إغلاق"
                        Margin="0,12,0,0"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="#90A4AE"
                        FontSize="12"
                        Command="{Binding CloseCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
